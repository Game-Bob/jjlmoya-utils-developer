---
import { Icon } from 'astro-icon/components';
import type { KnownLocale } from '../../types';
import type { MobileMockupGeneratorUI } from './ui';

interface Props {
  locale?: KnownLocale;
  ui?: Record<string, unknown>;
}

const { ui } = Astro.props;
const t = (ui ?? {}) as MobileMockupGeneratorUI;
---

<div id="mmg-root" data-i18n={JSON.stringify(t)} class="mmg-root">
  <div class="mmg-top-bar">
    <div class="mmg-top-actions">
      <button id="mmg-clear" style="display:none" class="mmg-btn-clear">
        <Icon name="mdi:trash-can-outline" class="mmg-btn-icon" />
        {t.btnClearAll}
      </button>
      <button id="mmg-download" style="display:none" class="mmg-btn-download">
        <Icon name="mdi:cloud-download" class="mmg-btn-icon" />
        {t.btnExport}
      </button>
    </div>
  </div>

  <div class="mmg-layout">
    <div class="mmg-panel">
      <div class="mmg-card">
        <h3 class="mmg-card-title">
          <Icon name="mdi:image-plus" class="mmg-card-icon" />
          {t.labelUpload}
        </h3>
        <div class="mmg-drop-zone">
          <input type="file" id="mmg-upload" accept="image/*" multiple class="mmg-file-input" />
          <input type="file" id="mmg-replace" style="display:none" accept="image/*" />
          <input type="file" id="mmg-mass-input" style="display:none" accept="image/*" multiple />
          <Icon name="mdi:cloud-upload" class="mmg-drop-icon" />
          <p class="mmg-drop-hint">{t.dropHint}</p>
          <p class="mmg-drop-formats">{t.dropFormats}</p>
        </div>
        <div class="mmg-mass-section">
          <button id="mmg-mass-btn" class="mmg-btn-mass">
            <Icon name="mdi:layers-triple-outline" class="mmg-btn-icon" />
            {t.btnMassReplace}
          </button>
          <p class="mmg-mass-hint">{t.massReplaceHint}</p>
        </div>
      </div>

      <div class="mmg-card mmg-settings-card">
        <h3 class="mmg-card-title">
          <Icon name="mdi:cog" class="mmg-card-icon" />
          {t.labelSettings}
        </h3>

        <div class="mmg-config-section">
          <label class="mmg-config-label">{t.labelDevice}</label>
          <div class="mmg-device-grid">
            <button class="mmg-device-btn mmg-device-active" data-device="iphone">
              <Icon name="mdi:apple" class="mmg-device-icon" />
              <span>iPhone</span>
            </button>
            <button class="mmg-device-btn" data-device="pixel">
              <Icon name="mdi:android" class="mmg-device-icon" />
              <span>Pixel</span>
            </button>
          </div>
        </div>

        <div class="mmg-config-section">
          <label class="mmg-config-label" for="mmg-font">{t.labelFont}</label>
          <select id="mmg-font" class="mmg-select">
            <option value="Inter">Inter</option>
            <option value="Outfit">Outfit</option>
            <option value="Poppins">Poppins</option>
            <option value="Montserrat">Montserrat</option>
            <option value="Playfair Display">Playfair Display</option>
          </select>
        </div>

        <div class="mmg-config-section">
          <div class="mmg-config-row">
            <label class="mmg-config-label">{t.labelBackground}</label>
            <button id="mmg-swap-colors" class="mmg-swap-btn" title={t.titleSwapColors}>
              <Icon name="mdi:swap-horizontal" class="mmg-swap-icon" />
            </button>
          </div>
          <div id="mmg-presets" class="mmg-presets-row"></div>
          <div class="mmg-gradient-inputs">
            <input type="color" id="mmg-grad-start" value="#6366f1" class="mmg-color-picker" />
            <Icon name="mdi:arrow-right" class="mmg-arrow-icon" />
            <input type="color" id="mmg-grad-end" value="#a855f7" class="mmg-color-picker" />
          </div>
          <div class="mmg-angle-section">
            <div class="mmg-angle-row">
              <span>{t.labelAngle}</span>
              <span id="mmg-angle-val">135&deg;</span>
            </div>
            <input type="range" id="mmg-grad-angle" min="0" max="360" value="135" class="mmg-range" />
          </div>
        </div>

        <div class="mmg-config-section mmg-safe-section">
          <div class="mmg-config-row">
            <label class="mmg-config-label">{t.labelSafeArea}</label>
            <button id="mmg-safe-toggle" class="mmg-toggle">
              <div id="mmg-safe-dot" class="mmg-toggle-dot"></div>
            </button>
          </div>
          <div class="mmg-safe-color-row">
            <input type="color" id="mmg-safe-color" value="#000000" class="mmg-color-picker-sm" />
            <span class="mmg-safe-color-label">{t.labelSafeAreaColor}</span>
          </div>
        </div>
      </div>
    </div>

    <div class="mmg-preview-area">
      <div id="mmg-empty" class="mmg-empty">
        <div class="mmg-empty-icon-wrap">
          <Icon name="mdi:image-multiple" class="mmg-empty-icon-svg" />
        </div>
        <h3 class="mmg-empty-title">{t.emptyTitle}</h3>
        <p class="mmg-empty-subtitle">{t.emptySubtitle}</p>
      </div>
      <div id="mmg-grid" style="display:none" class="mmg-preview-grid"></div>
    </div>
  </div>
</div>

<script>
  import { App } from './app';
  new App();
</script>

