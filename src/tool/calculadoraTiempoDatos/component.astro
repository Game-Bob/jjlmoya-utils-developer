---
import { Icon } from 'astro-icon/components';
import type { KnownLocale } from '../../types';
import type { CalculadoraTiempoDatosUI } from './ui';

interface Props {
  locale?: KnownLocale;
  ui?: Record<string, unknown>;
}

const { ui } = Astro.props;
const t = (ui ?? {}) as CalculadoraTiempoDatosUI;
---

<div id="ctd-root" data-i18n={JSON.stringify(t)} class="ctd-wrapper">
  <div class="ctd-card">
    <div class="ctd-header">
      <div class="ctd-icon">
        <Icon name="mdi:clock" />
      </div>
      <h2>{t.headerTitle}</h2>
    </div>

    <div class="ctd-input-section">
      <label for="ctd-size">
        {t.labelWebSize}
      </label>
      <div class="ctd-input-group">
        <input
          type="number"
          id="ctd-size"
          class="ctd-input"
          value="3.5"
          min="0.1"
          max="100"
          step="0.1"
        />
        <span class="ctd-input-unit">{t.unit}</span>
      </div>

      <div class="ctd-presets-label">{t.presetsLabel}</div>
      <div class="ctd-presets">
        <button class="ctd-preset" data-value="2.8" data-label="Instagram">
          Instagram
        </button>
        <button class="ctd-preset" data-value="2.5" data-label="TikTok">
          TikTok
        </button>
        <button class="ctd-preset" data-value="3.2" data-label="YouTube">
          YouTube
        </button>
        <button class="ctd-preset" data-value="1.8" data-label="Twitter/X">
          Twitter/X
        </button>
        <button class="ctd-preset active" data-value="2.2" data-label="Netflix">
          Netflix
        </button>
        <button class="ctd-preset" data-value="3.5" data-label="Discord">
          Discord
        </button>
      </div>
    </div>

    <div class="ctd-speed-section">
      <label>{t.labelSpeed}</label>
      <div class="ctd-speed-buttons">
        <button class="ctd-speed-btn" data-speed="3g">
          <span class="ctd-speed-label">{t.speedLabel3g}</span>
          <span class="ctd-speed-value">{t.speedValue3g}</span>
        </button>
        <button class="ctd-speed-btn active" data-speed="4g">
          <span class="ctd-speed-label">{t.speedLabel4g}</span>
          <span class="ctd-speed-value">{t.speedValue4g}</span>
        </button>
        <button class="ctd-speed-btn" data-speed="5g">
          <span class="ctd-speed-label">{t.speedLabel5g}</span>
          <span class="ctd-speed-value">{t.speedValue5g}</span>
        </button>
      </div>
    </div>

    <div class="ctd-multiplier-section">
      <label for="ctd-times">{t.labelTimes}</label>
      <div class="ctd-multiplier-input">
        <button class="ctd-times-btn" data-times="1">1x</button>
        <button class="ctd-times-btn" data-times="10">10x</button>
        <button class="ctd-times-btn active" data-times="50">50x</button>
        <button class="ctd-times-btn" data-times="100">100x</button>
        <button class="ctd-times-btn" data-times="200">200x</button>
        <input
          type="number"
          id="ctd-times"
          class="ctd-times-input"
          value="50"
          min="1"
          max="10000"
        />
      </div>
    </div>

    <div class="ctd-results">
      <div class="ctd-result-single">
        <div class="ctd-result-label">{t.resultSingleLoad}</div>
        <div class="ctd-result-time" id="ctd-single-time">1.4s</div>
        <div class="ctd-result-life" id="ctd-single-life">0.0000006%</div>
      </div>

      <div class="ctd-divider"></div>

      <div class="ctd-result-total">
        <div class="ctd-result-label">
          {t.resultDailyTotal} (<span id="ctd-times-display">50</span>x)
        </div>
        <div class="ctd-result-time-total" id="ctd-total-time">1m 10s</div>
        <div class="ctd-result-life-total" id="ctd-total-life">0.0000289%</div>
      </div>
    </div>

    <div class="ctd-impact">
      <div class="ctd-impact-card">
        <div class="ctd-impact-number" id="ctd-year-hours">8,760 h</div>
        <div class="ctd-impact-text">{t.resultTimePerYear}</div>
      </div>
      <div class="ctd-impact-card">
        <div class="ctd-impact-number" id="ctd-life-years">1.0 años</div>
        <div class="ctd-impact-text">{t.resultLifeYears}</div>
      </div>
    </div>

    <div class="ctd-message" id="ctd-message">
      <strong>{t.resultMessage}</strong>
    </div>
  </div>
</div>

<script>
  const LIFE_EXPECTANCY_SECONDS = 2522880000;
  const LIFE_EXPECTANCY_YEARS = 80;

  const SPEEDS: Record<string, number> = {
    '3g': 0.4,
    '4g': 10,
    '5g': 100,
  };

  const PRESETS: Record<string, string> = {
    '2.8': 'Instagram',
    '2.5': 'TikTok',
    '3.2': 'YouTube',
    '1.8': 'Twitter/X',
    '2.2': 'Netflix',
    '3.5': 'Discord',
  };

  let selectedSpeed = '4g';

  function calculateLoadTime(sizeMB: number, speedMbps: number): number {
    return (sizeMB * 8) / speedMbps;
  }

  function formatTime(seconds: number): string {
    if (seconds < 1) return Math.round(seconds * 1000) + 'ms';
    if (seconds < 60) return seconds.toFixed(1) + 's';
    const minutes = Math.floor(seconds / 60);
    const secs = Math.floor(seconds % 60);
    if (minutes < 60) return `${minutes}m ${secs}s`;
    const hours = Math.floor(minutes / 60);
    const mins = minutes % 60;
    return `${hours}h ${mins}m`;
  }

  function calculateLifePercent(seconds: number): number {
    return (seconds / LIFE_EXPECTANCY_SECONDS) * 100;
  }

  function updateTimeElements(singleTime: number, singleLife: number, totalTime: number, totalLife: number): void {
    const singleTimeEl = document.getElementById('ctd-single-time');
    const singleLifeEl = document.getElementById('ctd-single-life');
    const totalTimeEl = document.getElementById('ctd-total-time');
    const totalLifeEl = document.getElementById('ctd-total-life');

    if (singleTimeEl) singleTimeEl.textContent = formatTime(singleTime);
    if (singleLifeEl) singleLifeEl.textContent = singleLife.toFixed(7) + '%';
    if (totalTimeEl) totalTimeEl.textContent = formatTime(totalTime);
    if (totalLifeEl) totalLifeEl.textContent = totalLife.toFixed(7) + '%';
  }

  function updateImpactElements(totalTimePerYear: number): void {
    const yearHoursEl = document.getElementById('ctd-year-hours');
    const lifeYearsEl = document.getElementById('ctd-life-years');
    const yearHours = (totalTimePerYear / 3600).toFixed(0);
    const lifeYears = (totalTimePerYear / LIFE_EXPECTANCY_SECONDS) * LIFE_EXPECTANCY_YEARS;

    if (yearHoursEl) yearHoursEl.textContent = parseInt(yearHours).toLocaleString() + ' h';
    if (lifeYearsEl) lifeYearsEl.textContent = lifeYears.toFixed(2) + ' años';
  }

  function updateResults(): void {
    const sizeInput = document.getElementById('ctd-size') as HTMLInputElement;
    const timesInput = document.getElementById('ctd-times') as HTMLInputElement;

    if (!sizeInput || !timesInput) return;

    const size = parseFloat(sizeInput.value) || 0;
    const times = parseInt(timesInput.value) || 1;

    const singleTime = calculateLoadTime(size, SPEEDS[selectedSpeed]);
    const totalTime = singleTime * times;
    const totalTimePerYear = totalTime * 365;

    const singleLife = calculateLifePercent(singleTime);
    const totalLife = calculateLifePercent(totalTime);

    const timesDisplayEl = document.getElementById('ctd-times-display');
    if (timesDisplayEl) timesDisplayEl.textContent = times.toString();

    updateTimeElements(singleTime, singleLife, totalTime, totalLife);
    updateImpactElements(totalTimePerYear);
    updateMessage(times, size);
  }

  function updateMessage(times: number, size: number): void {
    const messageEl = document.getElementById('ctd-message');
    const appName = PRESETS[size.toFixed(1)] || 'esta app';
    const singleTime = calculateLoadTime(size, SPEEDS[selectedSpeed]);
    const totalTime = singleTime * times;
    const totalTimePerYear = totalTime * 365;
    const lifeYears = (totalTimePerYear / LIFE_EXPECTANCY_SECONDS) * LIFE_EXPECTANCY_YEARS;

    const message = `Has perdido aproximadamente ${lifeYears.toFixed(2)} años de vida esperando a que cargue ${appName}`;

    if (messageEl) messageEl.innerHTML = `<strong>${message}</strong>`;
  }

  function setupSpeedButtons(): void {
    const speedBtns = document.querySelectorAll('.ctd-speed-btn');
    speedBtns.forEach((btn) => {
      btn.addEventListener('click', (e) => {
        const target = e.currentTarget as HTMLButtonElement;
        const speed = target.dataset.speed;
        if (speed) {
          selectedSpeed = speed;
          speedBtns.forEach((b) => b.classList.remove('active'));
          target.classList.add('active');
          updateResults();
        }
      });
    });
  }

  function setupPresets(): void {
    const sizeInput = document.getElementById('ctd-size') as HTMLInputElement;
    const presets = document.querySelectorAll('.ctd-preset');
    presets.forEach((btn) => {
      btn.addEventListener('click', (e) => {
        const target = e.currentTarget as HTMLButtonElement;
        const value = target.dataset.value;
        if (value && sizeInput) {
          sizeInput.value = value;
          presets.forEach((b) => b.classList.remove('active'));
          target.classList.add('active');
          updateResults();
        }
      });
    });
  }

  function setupTimesButtons(): void {
    const timesInput = document.getElementById('ctd-times') as HTMLInputElement;
    const timesBtns = document.querySelectorAll('.ctd-times-btn');
    timesBtns.forEach((btn) => {
      btn.addEventListener('click', (e) => {
        const target = e.currentTarget as HTMLButtonElement;
        const times = target.dataset.times;
        if (times && timesInput) {
          timesInput.value = times;
          timesBtns.forEach((b) => b.classList.remove('active'));
          target.classList.add('active');
          updateResults();
        }
      });
    });
  }

  function initCalculator(): void {
    const sizeInput = document.getElementById('ctd-size') as HTMLInputElement;
    const timesInput = document.getElementById('ctd-times') as HTMLInputElement;

    sizeInput?.addEventListener('input', updateResults);
    timesInput?.addEventListener('input', updateResults);

    setupSpeedButtons();
    setupPresets();
    setupTimesButtons();

    updateResults();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCalculator);
  } else {
    initCalculator();
  }
</script>

<style>
  .ctd-wrapper {
    --ctd-primary: #6366f1;
    --ctd-secondary: #8b5cf6;
    --ctd-accent: #ec4899;

    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1rem;
    min-height: 100vh;
  }

  .ctd-card {
    background: white;
    border-radius: 2.5rem;
    padding: 3rem;
    max-width: 700px;
    width: 100%;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.15);
  }

  :global(.theme-dark) .ctd-card {
    background: rgb(30, 41, 59);
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
  }

