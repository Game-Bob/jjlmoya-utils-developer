    display: block;
    font-size: 0.85rem;
    font-weight: 700;
    color: rgb(100, 116, 139);
    margin-bottom: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  :global(.theme-dark) .ctd-speed-section > label {
